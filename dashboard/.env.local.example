# ============================================================
# Fuja do Mico — Dashboard — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commitar .env.local no git.
#
# Para obter os valores:
#   SUPABASE_URL e SUPABASE_ANON_KEY: Supabase → Settings → API
#   ANTHROPIC_API_KEY: console.anthropic.com → API Keys
# ============================================================

# Supabase — públicas (browser pode acessar — protegidas por RLS)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua_anon_key

# Claude API — server-side apenas (NUNCA usar prefixo NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-...sua_chave
